theme_override_font_sizes/font_size = 17
theme_override_colors/font_color = Color(1.0, 0.55, 0.15, 1)

[node name="InteractLabel" type="Label" parent="Row/P1Block/InteractGroup"]
text = "Interact"
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.75, 0.75, 0.75, 1)

; ── sit group ──
[node name="SitGroup" type="VBoxContainer" parent="Row/P1Block"]
theme_override_constants/separation = 1

[node name="SitKey" type="Label" parent="Row/P1Block/SitGroup"]
